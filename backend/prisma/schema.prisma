generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  passwordHash        String
  role                UserRole            @default(USER)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  emailVerified       Boolean             @default(false)
  isActive            Boolean             @default(true)
  name                String
  referralCode        String?             @unique
  referredBy          String?
  apiKeys             ApiKey[]
  orders              Order[]
  payments            Payment[]
  purchasedSocialLogs SocialLog[]         @relation("PurchasedSocialLogs")
  wallet              Wallet?
  transactions        WalletTransaction[]

  @@index([email])
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// *
///  * ============================================================
///  * WALLET TRANSACTIONS
///  * ============================================================
model WalletTransaction {
  id            String            @id @default(uuid())
  userId        String
  type          TransactionType
  amount        Decimal           @db.Decimal(18, 2)
  description   String
  reference     String            @unique
  createdAt     DateTime          @default(now())
  balanceAfter  Decimal?          @db.Decimal(18, 2)
  balanceBefore Decimal?          @db.Decimal(18, 2)
  metadata      Json?
  status        TransactionStatus @default(PENDING)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reference])
  @@index([status])
  @@index([createdAt])
}

model SocialLog {
  id              String             @id @default(cuid())
  platform        SocialPlatform
  country         String?
  username        String
  age             Int
  followers       Int?
  price           Decimal            @db.Decimal(10, 2)
  emailAttached   Boolean            @default(false)
  phoneAttached   Boolean            @default(false)
  twoFactor       Boolean            @default(false)
  ogEmail         Boolean            @default(false)
  verified        Boolean            @default(false)
  description     String?
  image           String?
  status          SocialLogStatus    @default(AVAILABLE)
  buyerId         String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  backupCodes     Json?
  cookies         Json?
  /// PRIVATE LOGIN DETAILS
  loginEmail      String?
  loginPhone      String?
  notes           String?
  password        String?
  recoveryEmail   String?
  twoFactorSecret String?
  purchasedAt     DateTime?
  category        SocialLogCategory
  pageType        SocialLogPageType?
  buyer           User?              @relation("PurchasedSocialLogs", fields: [buyerId], references: [id])

  @@index([buyerId])
  @@index([status])
  @@index([platform])
  @@index([category])
}

model Order {
  id              String       @id @default(uuid())
  userId          String
  providerOrderId String?
  country         String
  operator        String
  service         String
  phoneNumber     String?
  providerCostUsd Decimal      @db.Decimal(18, 4)
  sellingPriceNgn Decimal      @db.Decimal(18, 2)
  status          OrderStatus  @default(PENDING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  activationType  String
  provider        String       @default("FIVESIM")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  smsMessages     SmsMessage[]

  @@index([userId])
  @@index([providerOrderId])
  @@index([status])
  @@index([country])
  @@index([service])
  @@index([activationType])
}

model SmsMessage {
  id         String   @id @default(uuid())
  orderId    String
  code       String?
  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  fullText   String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model PricingRule {
  id             String   @id @default(uuid())
  country        String
  service        String
  markupPercent  Float
  createdAt      DateTime @default(now())
  fixedMarkupNgn Decimal  @default(0) @db.Decimal(18, 2)

  @@index([country])
  @@index([service])
}

model Payment {
  id               String        @id @default(uuid())
  userId           String
  reference        String        @unique
  amount           Decimal       @db.Decimal(18, 2)
  status           PaymentStatus @default(PENDING)
  createdAt        DateTime      @default(now())
  gatewayReference String?
  providerResponse Json?
  updatedAt        DateTime      @updatedAt
  currency         String        @default("NGN")
  paidAt           DateTime?
  provider         String        @default("PAYSTACK")
  verifiedAt       DateTime?
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([reference])
  @@index([status])
  @@index([userId])
}

model ApiKey {
  id        String   @id @default(uuid())
  userId    String
  key       String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum UserRole {
  USER
  ADMIN
}

enum TransactionType {
  CREDIT
  DEBIT
  DEPOSIT
  PURCHASE
  REFUND
  TRANSFER
}

enum OrderStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  FAILED
  BANNED
  TIMEOUT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TIKTOK
  X
  SNAPCHAT
  TELEGRAM
  DISCORD
  REDDIT
  LINKEDIN
  YOUTUBE
  GMAIL
  OUTLOOK
  VPN
  TEXTPLUS
  NEXTPLUS
  MAIL
}

enum SocialLogCategory {
  FACEBOOK_PAGE
  FACEBOOK_COUNTRY
  TWITTER_FOLLOWERS
  INSTAGRAM_FOLLOWERS
  VPN
  TEXTPLUS_NEXTPLUS
  TELEGRAM_ACCOUNT
  TIKTOK_COUNTRY
  TIKTOK_FOLLOWERS
  MAIL
}

enum SocialLogPageType {
  CREATE_PAGE
  CREATED_PAGE
  MULTI_PAGE
  PAGE_WITH_FOLLOWERS
}

enum SocialLogStatus {
  AVAILABLE
  SOLD
}
